                            <div style="font-size: 2rem;">📸</div>
                            <div style="color: #10b981; font-weight: 700; margin-top: 10px;">Análisis Imágenes IA</div>
                        </div><div style="background: rgba(16, 185, 129, 0.1); border: 2px solid #10b981; border-radius: 12px; padding: 20px; text-align: center;">
                            <div style="font-size: 2rem;">💰</div>
                            <div style="color: #10b981; font-weight: 700; margin-top: 10px;">Presupuestos Automáticos</div>
                        </div><div style="background: rgba(16, 185, 129, 0.1); border: 2px solid #10b981; border-radius: 12px; padding: 20px; text-align: center;">
                            <div style="font-size: 2rem;">📊</div>
                            <div style="color: #10b981; font-weight: 700; margin-top: 10px;">Base APUs Real</div>
                        </div><div style="background: rgba(16, 185, 129, 0.1); border: 2px solid #10b981; border-radius: 12px; padding: 20px; text-align: center;">
