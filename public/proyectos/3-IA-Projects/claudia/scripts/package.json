{
  "name": "claudia-build-tools",
  "version": "7.1.0",
  "description": "Build and optimization tools for CLAUDIA",
  "private": true,
  "scripts": {
    "build": "node build-optimized.js",
    "bundle": "node build-optimized.js",
    "minify:js": "npx terser ../web_app/js/claudia.bundle.js -c passes=3,pure_funcs=['console.log','console.debug'],drop_console=true,toplevel=true -m toplevel,eval --source-map -o ../web_app/js/claudia.bundle.min.js",
    "minify:lazy": "npm run minify:photos && npm run minify:calendar && npm run minify:pdf && npm run minify:voice && npm run minify:collaboration",
    "minify:photos": "npx terser ../web_app/js/claudia-photos.js -c passes=2,toplevel=true -m toplevel -o ../web_app/js/claudia-photos.min.js",
    "minify:calendar": "npx terser ../web_app/js/claudia-calendar.js -c passes=2,toplevel=true -m toplevel -o ../web_app/js/claudia-calendar.min.js",
    "minify:pdf": "npx terser ../web_app/js/claudia-pdf-export.js -c passes=2,toplevel=true -m toplevel -o ../web_app/js/claudia-pdf-export.min.js",
    "minify:voice": "npx terser ../web_app/js/claudia-voice.js -c passes=2,toplevel=true -m toplevel -o ../web_app/js/claudia-voice.min.js",
    "minify:collaboration": "npx terser ../web_app/js/claudia-collaboration.js -c passes=2,toplevel=true -m toplevel -o ../web_app/js/claudia-collaboration.min.js",
    "minify:css": "npx csso ../web_app/css/claudia.css -o ../web_app/css/claudia.min.css",
    "compress": "npm run compress:bundle && npm run compress:lazy",
    "compress:bundle": "brotli -q 11 ../web_app/js/claudia.bundle.min.js -o ../web_app/js/claudia.bundle.min.js.br",
    "compress:lazy": "brotli -q 11 ../web_app/js/claudia-*.min.js -o {}.br",
    "analyze": "node analyze-bundle.js",
    "check-budgets": "node check-budgets.js",
    "test:perf": "node check-budgets.js",
    "full-build": "npm run build && npm run minify:js && npm run minify:lazy && npm run check-budgets",
    "ci": "npm run full-build && npm run check-budgets",
    "test": "jest"
  },
  "devDependencies": {
    "csso-cli": "^4.0.2",
    "eslint": "^9.38.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "terser": "^5.44.0"
  }
}
