{
  "name": "claudia-tests",
  "version": "7.0.0",
  "description": "Unit tests for CLAUDIA v7.0",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["testing", "claudia", "jest"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "fake-indexeddb": "^6.2.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": [
      "../web_app/js/claudia-utils.js",
      "../web_app/js/claudia-indexeddb.js",
      "../web_app/js/claudia-compression.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 50,
        "branches": 50,
        "functions": 50,
        "lines": 50
      }
    }
  }
}
