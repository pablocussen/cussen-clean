                        <li><span>🛰️</span> <p><strong>Google Earth Engine</strong> - Datos satelitales</p></li>
                        <li><span>📡</span> <p><strong>Sentinel-2</strong> - Imágenes multiespectrales</p></li>
                        <li><span>☁️</span> <p><strong>Vercel</strong> - Hosting serverless</p></li>
                        <li><span>📊</span> <p><strong>Chart.js</strong> - Visualizaciones</p></li>
